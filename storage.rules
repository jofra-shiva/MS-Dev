rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── User avatars ──────────────────────────────────────────
    match /users/{userId}/avatar/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024  // 2MB max
        && request.resource.contentType.matches('image/.*');
    }

    // ── Task attachments ──────────────────────────────────────
    match /projects/{projectId}/tasks/{taskId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024  // 20MB max
        && request.resource.contentType.matches('(image|application|text)/.*');
    }

    // ── Project assets ────────────────────────────────────────
    match /projects/{projectId}/assets/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
